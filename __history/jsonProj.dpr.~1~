program jsonProj;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  System.JSON,
  System.JSON.Types,
  Rest.Json,
  System.SysUtils;



var
  Obj: TJsonObject;
  Arr: TJsonArray;

begin
  Obj := TJsonObject.Create;

  try
    Obj.AddPair('nome:', 'Joăo');
    Obj.AddPair('idade:', TJsonNumber.Create(18));
    Obj.AddPair('Ativo:', TJsonBool.Create(true));

    Arr:= TJsonArray.Create;
    Arr.Add('item1');
    Arr.Add('item2');
    Obj.AddPair('Lista:', Arr);


  finally
      Obj.Free;
  end;
end.
